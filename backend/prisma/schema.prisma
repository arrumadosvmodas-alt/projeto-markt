generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(cuid())
  cpf                String     @unique
  passwordHash       String
  name               String
  email              String?
  resetToken         String?
  resetTokenExpires  DateTime?
  createdAt          DateTime   @default(now())
  purchases    Purchase[]
  markets      Market[]   @relation("MarketCreatedBy")
  avatarUrl          String? // Foto do perfil em Base64 ou URL
  subscriptionType   String    @default("free_trial") // "free_trial" | "monthly" | "yearly"
  subscriptionStart  DateTime  @default(now())
  subscriptionEnd    DateTime  @default(now())
  queuedPlan         String? // "monthly" | "yearly"
  queuedPlanEnd      DateTime?
  walletCycleDay     Int           @default(5)
  walletLastPrompted DateTime?
  walletLimits       WalletLimit[]
  shoppingLists      ShoppingList[]
}

model Market {
  id              String     @id @default(cuid())
  name            String
  address         String?
  lat             Float?
  lng             Float?
  source          String // "osm" | "manual"
  externalId      String?
  createdByUserId String?
  createdBy       User?      @relation("MarketCreatedBy", fields: [createdByUserId], references: [id])
  purchases       Purchase[]
  createdAt       DateTime   @default(now())

  @@index([createdByUserId])
}

model Purchase {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  marketId     String
  market       Market         @relation(fields: [marketId], references: [id])
  budgetLimit  Float?
  status       String         @default("open") // "open" | "completed"
  totalAmount  Float          @default(0)
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  items        PurchaseItem[]
  paymentMethod String? // "a_vista" | "credito" | "alimentacao" | "misto"
  paymentDetails String? // JSON ou texto detalhando as formas de pagamento
  shoppingListId String?
  shoppingList   ShoppingList?  @relation(fields: [shoppingListId], references: [id])
  shoppingListReport PurchaseShoppingListReport?

  @@index([userId, status])
  @@index([userId, completedAt])
}

model Product {
  id        String         @id @default(cuid())
  barcode   String         @unique
  name      String
  brand     String?
  category  String?
  imageUrl  String?
  source    String // "openfoodfacts" | "manual"
  createdAt DateTime       @default(now())
  items     PurchaseItem[]

  @@index([category])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  quantity   Float
  subtotal   Float
  createdAt  DateTime @default(now())

  @@index([productId, createdAt])
  @@index([purchaseId])
}

model WalletLimit {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  cycleStartDate   DateTime
  cycleEndDate     DateTime
  limitDebito      Float
  limitCredito     Float
  limitAlimentacao Float
  limitOutros      Float
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([userId, cycleStartDate])
}

model ShoppingList {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  name      String
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  items     ShoppingListItem[]
  purchases Purchase[]
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now())
}

model PurchaseShoppingListReport {
  id             String                         @id @default(cuid())
  purchaseId     String                         @unique
  purchase       Purchase                       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  shoppingListId String
  name           String
  items          PurchaseShoppingReportItem[]
}

model PurchaseShoppingReportItem {
  id                           String                     @id @default(cuid())
  purchaseShoppingListReportId String
  report                       PurchaseShoppingListReport @relation(fields: [purchaseShoppingListReportId], references: [id], onDelete: Cascade)
  name                         String
  status                       String                     // "bought" | "not_found"
}
